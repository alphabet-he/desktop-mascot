{
  "name": "desktop-companion",
  "version": "2.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "npx electron-packager . --platform=darwin --arch=x64 --asar --out=dist --overwrite && node scripts/postbuild.js",
    "build:win": "npx electron-packager . --platform=win32 --arch=x64 --asar --out=dist --overwrite && node scripts/postbuild.js",
    "build": "npm run build:mac && npm run build:win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "wordcloud": "^1.2.3"
  }
}
